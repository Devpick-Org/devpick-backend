        },
        {
          "name": "질문 목록 조회 - kotlin 태그",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.stackexchange.com/2.3/questions?order=desc&sort=activity&site=stackoverflow&filter=withbody&pagesize=5&tagged=kotlin",
              "protocol": "https",
              "host": ["api", "stackexchange", "com"],
              "path": ["2.3", "questions"],
              "query": [
                { "key": "order", "value": "desc" },
                { "key": "sort", "value": "activity" },
                { "key": "site", "value": "stackoverflow" },
                { "key": "filter", "value": "withbody" },
                { "key": "pagesize", "value": "5" },
                { "key": "tagged", "value": "kotlin" }
              ]
            }
          }
        },
        {
          "name": "쿼터 잔량 확인",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.stackexchange.com/2.3/questions?order=desc&sort=activity&site=stackoverflow&pagesize=1",
              "protocol": "https",
              "host": ["api", "stackexchange", "com"],
              "path": ["2.3", "questions"],
              "query": [
                { "key": "order", "value": "desc" },
                { "key": "sort", "value": "activity" },
                { "key": "site", "value": "stackoverflow" },
                { "key": "pagesize", "value": "1" }
              ]
            },
            "description": "응답의 quota_remaining 값으로 잔량 확인\nAPI 키 없음: 일 300회 / 있음: 일 10,000회"
          }
        }
      ]
    }
  ]
}
